{
  "name": "healthcare-blockchain",
  "version": "1.0.0",
  "description": "Blockchain-enabled healthcare demo with React, Express, MongoDB, Hardhat, and IPFS-backed records.",
  "main": "index.js",
  "scripts": {
    "contracts:compile": "npx hardhat compile",
    "contracts:node": "npx hardhat node",
    "contracts:deploy": "npx hardhat run scripts/deploy.js --network localhost",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "backend:test": "npm --prefix backend run test",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:test": "npm --prefix frontend run test",
    "test": "npm run backend:test && npm run frontend:test"
  },
  "keywords": [
    "blockchain",
    "healthcare",
    "react",
    "express",
    "hardhat",
    "ipfs"
  ],
  "author": "Healthcare Trust Project",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@types/node": "^22.19.15",
    "ethers": "^5.8.0",
    "hardhat": "^2.22.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
  }
}
